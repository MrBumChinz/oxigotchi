[main]
name = "oxigotchi"
whitelist = ["YourHomeSSID", "YourHomeSSID-5G"]
lang = "en"
iface = "wlan0mon"
mon_start_cmd = "/usr/bin/monstart"
mon_stop_cmd = "/usr/bin/monstop"
mon_max_blind_epochs = 5
no_restart = false
confd = "/etc/pwnagotchi/conf.d/"
custom_plugin_repos = [ "https://github.com/jayofelony/pwnagotchi-torch-plugins/archive/master.zip", "https://github.com/Sniffleupagus/pwnagotchi_plugins/archive/master.zip", "https://github.com/NeonLightning/pwny/archive/master.zip", "https://github.com/marbasec/UPSLite_Plugin_1_3/archive/master.zip", "https://github.com/wpa-2/Pwnagotchi-Plugins/archive/master.zip", "https://github.com/cyberartemio/wardriver-pwnagotchi-plugin/archive/main.zip",]
custom_plugins = "/usr/local/share/pwnagotchi/custom-plugins/"
[main.plugins.walkby]
enabled = true
min_rssi = -70
deauth_per_client = 3
assoc_per_ap = 2
cooldown = 20
show_status = true
status_position = [0, 95]

[main.plugins.wpa-sec]
enabled = false
api_key = ""
api_url = "https://wpa-sec.stanev.org"
download_results = false
show_pwd = false
single_files = false

[main.plugins.wpa-sec.main.plugins.wpa-sec]
enabled = false
api_key = ""
api_url = "https://wpa-sec.stanev.org"
download_results = true


[main.plugins.bt-tether]
enabled = false
phone-name = ""
phone = "android"
ip = "192.168.44.44"
mac = ""
gateway = "192.168.44.1"
dns = "8.8.8.8 1.1.1.1"
show_on_screen = true
show_mini_status = true
mini_status_position = [90, 0]  # Position [x, y] for mini status (default: [110, 0])
show_detailed_status = true
detailed_status_position = [0, 95]  # Position for detailed status (default: [0, 82])
auto_reconnect = true
reconnect_interval = 60  # Check connection every N seconds (default: 60)
reconnect_failure_cooldown = 300  # Cooldown after max failures in seconds (default: 300 = 5 minutes)
discord_webhook_url = ""

[main.plugins.pisugarx]
enabled = true
rotation = false
default_display = "percentage"
lowpower_shutdown = true
lowpower_shutdown_level = 15
max_charge_voltage_protection = false

[main.plugins.auto-tune]
enabled = false
show_hidden = false
reset_history = true
extra_channels = 5
show_interactions = false

[main.plugins.auto_backup]
enabled = true
interval = "daily"
max_tries = 0
backup_location = "/home/pi/"
files = [ "/root/settings.yaml", "/root/client_secrets.json", "/root/.api-report.json", "/root/.ssh", "/root/.bashrc", "/root/.profile", "/home/pi/handshakes", "/root/peers", "/etc/pwnagotchi/", "/usr/local/share/pwnagotchi/custom-plugins", "/etc/ssh/", "/home/pi/.bashrc", "/home/pi/.profile", "/home/pi/.wpa_sec_uploads",]
exclude = [ "/etc/pwnagotchi/logs/*",]
commands = [ "tar cf {backup_file} {files}",]

[main.plugins.auto-update]
install = true
interval = 1
token = ""
enabled = false

[main.plugins.fix_services]
enabled = true

[main.plugins.cache]
enabled = true

[main.plugins.gdrivesync]
backupfiles = [ "",]
backup_folder = "PwnagotchiBackups"
interval = 1
enabled = false

[main.plugins.gpio_buttons]
enabled = false

[main.plugins.gps]
speed = 19200
device = "/dev/ttyUSB0"
enabled = false

[main.plugins.gps_listener]
enabled = false

[main.plugins.grid]
enabled = true
report = true

[main.plugins.logtail]
enabled = true
max-lines = 10000

[main.plugins.memtemp]
enabled = false
scale = "celsius"
orientation = "horizontal"

[main.plugins.ohcapi]
api_key = ""
receive_email = "yes"
enabled = false

[main.plugins.pwndroid]
gateway = "192.168.44.1"
display = false
display_altitude = false
enabled = false

[main.plugins.pwncrack]
key = ""
enabled = false

[main.plugins.session-stats]
save_directory = "/var/tmp/pwnagotchi/sessions/"
enabled = false

[main.plugins.ups_hat_c]
label_on = true
shutdown = 5
bat_x_coord = 140
bat_y_coord = 0
enabled = false

[main.plugins.ups_lite]
shutdown = 2
enabled = false

[main.plugins.webcfg]
enabled = true

[main.plugins.webgpsmap]
enabled = false

[main.plugins.wigle]
api_key = ""
cvs_dir = "/tmp"
donate = false
timeout = 30
position = [ 7, 85,]
enabled = false

[main.plugins.memtemp-plus]
enabled = true
scale = "celsius"
orientation = "horizontal"
fields = "mem,cpu,freq,temp"
position = "155,83"
linespacing = 12

[main.plugins.tweak_view]
enabled = true

[main.plugins.exp]
enabled = true
lvl_x_coord = 130
lvl_y_coord = 72
exp_x_coord = 168
exp_y_coord = 72
bar_symbols_count = 12

[main.plugins.better_quickdic]
enabled = true
face = "(·ω·)"
wordlist_folder = "/home/pi/wordlists/"

[main.plugins.display-password]
enabled = true
orientation = "horizontal"

[main.plugins.handshakes-dl]
enabled = true

[main.plugins.IPDisplay]
enabled = true
skip_devices = [ "lo", "usb0",]

[main.plugins.internet-connection]
position = "163,6"
enabled = true

[main.plugins.instattack]

[main.plugins.wpa-sec-list]
enabled = false

[main.plugins.enable_assoc]
enabled = true
position = "166,112"

[main.plugins.enable_deauth]
enabled = true
position = "189,112"

[main.plugins.button-feedback]
enabled = true

[main.plugins.example]

[main.plugins.switcher]

[main.plugins.angryoxide]
enabled = true
binary_path = "/usr/local/bin/angryoxide"
interface = "wlan0mon"
nexmon_mode = true              # enable injection throttling for brcmfmac/nexmon chips
injection_delay_ms = 500        # ms between injected frames (~2 fps, tune based on chip stability)
channel_dwell_ms = 5000         # ms to dwell per channel (nexmon needs longer than default 100ms)
output_dir = "/etc/pwnagotchi/handshakes/"
notx = false                    # passive-only mode (no injection, capture only)
extra_args = ""                 # additional angryoxide CLI arguments
max_crashes = 10                # stop retrying after this many crashes
adaptive_throttle = false       # auto-tune injection_delay_ms based on stability
delay_min = 100                 # minimum injection delay for adaptive throttle (ms)
delay_max = 2000                # maximum injection delay for adaptive throttle (ms)

[main.plugins.pwnstore_ui]
enabled = true


[main.log]
path = "/etc/pwnagotchi/log/pwnagotchi.log"
path-debug = "/etc/pwnagotchi/log/pwnagotchi-debug.log"

[main.log.rotation]
size = "10M"
enabled = true



[personality]
recon_time = 15
hop_recon_time = 5
min_recon_time = 3
max_interactions = 5
max_misses_for_recon = 8
throttle_a = 0.1
throttle_d = 0.3
ap_ttl = 60
sta_ttl = 120
excited_num_epochs = 5
bored_num_epochs = 25
sad_num_epochs = 40
channels = []
min_rssi = -200
deauth = true
associate = true
max_inactive_scale = 3
recon_inactive_multiplier = 3
advertise = true
bond_encounters_factor = 20000
frame_padding = true
frame_padding_min_bytes = 650     # minimum frame size in bytes (650+ avoids PSM timing issues)

[ui]
invert = true
cursor = true
fps = 0.0
[ui.faces]
look_r = ["( ⚆_⚆)", "(☉_☉ )"]
look_l = ["(☉_☉ )", "( ⚆_⚆)"]
look_r_happy = ["( ◕‿◕)", "( ≧◡≦)"]
look_l_happy = ["(◕‿◕ )", "(≧◡≦ )"]
intense = ["(°▃▃°)", "(°ロ°)"]
cool = ["(⌐■_■)"]
happy = ["(•‿‿•)", "(^‿‿^)"]
excited = ["(ᵔ◡◡ᵔ)", "(✜‿‿✜)"]
grateful = ["(^‿‿^)"]
motivated = ["(☼‿‿☼)", "(★‿★)"]
bored = ["(-__-)", "(—__—)"]
awake = ["(◕‿‿◕)"]
sleep = ["(⇀‿‿↼)", "(≖‿‿≖)"]
demotivated = ["(☼‿‿☼)", "(★‿★)"]
smart = [ "(✜‿‿✜)",]
lonely = [ "(ب__ب)",]
sad = [ "(╥☁╥ )",]
angry = [ "(-_-')", "(⇀__⇀)", "(`___´)",]
friend = [ "(♥‿‿♥)", "(♡‿‿♡)", "(♥‿♥ )", "(♥ω♥ )",]
broken = [ "(☓‿‿☓)",]
debug = [ "(#__#)",]
upload = [ "(1__0)", "(1__1)", "(0__1)",]
png = true
position_x = 0
position_y = 34

[ui.display]
enabled = true
type = "waveshare_4"
rotation = 180

[ui.font]
name = "DejaVuSansMono"
size_offset = 0

[ui.web]
address = "::"
auth = false
username = "changeme"
password = "changeme"
origin = ""
port = 8080
on_frame = ""
enabled = true

[ui.web.theme]
# Theme customization for the web interface. Use RGB values for the accent color.
accent_r = 76
accent_g = 175
accent_b = 80


[bettercap]
handshakes = "/home/pi/handshakes"
silence = [ "ble.device.new", "ble.device.lost", "ble.device.service.discovered", "ble.device.characteristic.discovered", "ble.device.disconnected", "ble.device.connected", "ble.connection.timeout", "wifi.client.new", "wifi.client.lost", "wifi.client.probe", "wifi.ap.new", "wifi.ap.lost", "mod.started",]

[fs.memory]
enabled = true

[fs.memory.mounts.log]
mount = "/etc/pwnagotchi/log/"
size = "50M"
sync = 60
zram = true
rsync = true
enabled = true

[fs.memory.mounts.data]
mount = "/var/tmp/pwnagotchi"
size = "10M"
sync = 3600
zram = true
rsync = true
enabled = true



[bluetooth]
enabled = true
phone_name = ""
auto_pair = true
auto_connect = true
# Stay discoverable even after a successful tether so users can pair a
# second phone later without toggling anything in the web UI. Set to true
# if you want the adapter to go invisible once connected.
hide_after_connect = false
